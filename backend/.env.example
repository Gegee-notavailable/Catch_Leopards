# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# URL ของ IP Webcam บนมือถือ (ดูใน app หลังเปิดใช้งาน)
IP_CAMERA_URL=http://192.168.x.x:8080/video

# Token ของ LINE Notify (สร้างได้ที่ https://notify-bot.line.me/my/)
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# Path ไปยัง Service Account JSON ที่ดาวน์โหลดจาก Firebase Console
FIREBASE_CREDENTIALS_PATH=./app/firebase-credentials.json

# ช่วงเวลา inference (วินาที) — 1.0 = ทุก 1 วินาที
PROCESS_INTERVAL=1.0
